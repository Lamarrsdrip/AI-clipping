PORT=4173
APP_BASE_URL=http://localhost:4173
WATCH_INTERVAL_MINUTES=15
CLIP_JOB_CREDIT_COST=5

# Required for real YouTube channel imports.
YOUTUBE_API_KEY=

# Required for AI reasoning. Emergent defaults to https://api.emergent.sh/v1.
LLM_PROVIDER=emergent
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4o-mini

# Optional fallback provider. Leave empty until needed.
LLM_FALLBACK_PROVIDER=
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_BASE_URL=
LLM_FALLBACK_MODEL=

# Production database target. The local MVP uses SQLite because no Postgres
# client is installed in this environment.
DATABASE_URL=postgres://clipforge:clipforge@localhost:5432/clipforge

# Optional storage target for generated assets.
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Absolute paths can override PATH lookup.
YTDLP_PATH=yt-dlp
FFMPEG_PATH=ffmpeg
