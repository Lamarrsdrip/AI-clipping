# -------------------------------------------------------
# ClipForge AI — Environment Variables
# Copy this file to .env and fill in the values.
# -------------------------------------------------------

# Server
PORT=4173
APP_BASE_URL=http://localhost:4173
HOST=127.0.0.1

# -------------------------------------------------------
# REQUIRED for clip generation
# Install locally: brew install ffmpeg
# Included in Docker image automatically.
# -------------------------------------------------------
FFMPEG_PATH=ffmpeg

# -------------------------------------------------------
# REQUIRED for YouTube link imports
# Install locally: pip install yt-dlp  OR  brew install yt-dlp
# Included in Docker image automatically.
# -------------------------------------------------------
YTDLP_PATH=yt-dlp

# -------------------------------------------------------
# AI provider — required for viral moment detection,
# hook generation, captions, and hashtags.
#
# Supported: openai, emergent (OpenAI-compatible)
# Emergent default base URL: https://api.emergent.sh/v1
# -------------------------------------------------------
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4o-mini

# Optional fallback provider (used if primary fails)
LLM_FALLBACK_PROVIDER=
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_BASE_URL=
LLM_FALLBACK_MODEL=

# -------------------------------------------------------
# Whisper transcription for uploaded videos
# Uses the same API key as LLM_API_KEY (OpenAI).
# If the LLM provider is not OpenAI-compatible for
# Whisper, set a separate key here.
# -------------------------------------------------------
# WHISPER_API_KEY=   (defaults to LLM_API_KEY if not set)

# -------------------------------------------------------
# YouTube Data API v3 — optional but improves metadata
# quality for YouTube imports. Falls back to yt-dlp.
# Get key at console.cloud.google.com
# -------------------------------------------------------
YOUTUBE_API_KEY=

# -------------------------------------------------------
# Billing (optional)
# -------------------------------------------------------
CREDITS_ENABLED=false
CLIP_JOB_CREDIT_COST=5

# -------------------------------------------------------
# Stripe — optional, for card billing
# -------------------------------------------------------
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# -------------------------------------------------------
# Storage — optional, for S3/Cloudflare R2
# Without this, files are stored in ./storage/
# -------------------------------------------------------
# S3_ENDPOINT=
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# -------------------------------------------------------
# Database — optional, for production Postgres
# Without this, app uses ./data/db.json (fine for MVP)
# -------------------------------------------------------
# DATABASE_URL=postgres://user:pass@host:5432/clipforge

# -------------------------------------------------------
# Processing limits
# -------------------------------------------------------
MAX_UPLOAD_BYTES=314572800
MAX_CONCURRENT_RENDER_JOBS=1
PROCESS_TIMEOUT_MS=600000
RENDER_WIDTH=720
RENDER_HEIGHT=1280
MIN_CLIP_SOURCE_SECONDS=15
IMPORT_RATE_LIMIT_MS=8000
YTDLP_BLOCK_COOLDOWN_MS=900000
AI_TIMEOUT_MS=45000
JOB_STALE_MS=720000
MAX_RSS_MB=420
WATCH_INTERVAL_MINUTES=15
